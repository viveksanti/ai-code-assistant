generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalysisHistory {
  id        String   @id @default(cuid())
  code      String
  language  String
  action    String
  result    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}